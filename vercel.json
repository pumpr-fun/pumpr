{
  "version": 2,
  "crons": [
    {
      "path": "/api/referrals/cron",
      "schedule": "0 * * * *"
    }
  ],
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "artifacts/**",
          "cache/**",
          "frontend/**",
          "node_modules/@solana/web3.js/lib/index.browser.cjs.js"
        ]
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "headers": [
    {
      "source": "/js/sidebar.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "Content-Type", "value": "application/json; charset=utf-8" }
      ]
    },
    {
      "source": "/downloads/(.*)\\.apk",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "Content-Type", "value": "application/vnd.android.package-archive" },
        { "key": "Content-Disposition", "value": "attachment" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; media-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https://api.geckoterminal.com https://api.dexscreener.com https://withered-hidden-ensemble.quiknode.pro https://*.quiknode.pro; frame-src 'self' https://www.geckoterminal.com https://trade.padre.gg; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/downloads/(.*)",
      "dest": "/frontend/downloads/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "/data/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/vendor/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(favicon\\.ico|robots\\.txt)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/manifest\\.webmanifest$",
      "dest": "/frontend/manifest.webmanifest"
    },
    {
      "src": "/service-worker\\.js$",
      "dest": "/frontend/service-worker.js"
    },
    {
      "src": "/\\.well-known/(.*)",
      "dest": "/frontend/.well-known/$1"
    },
    {
      "src": "/create$",
      "dest": "/frontend/create.html"
    },
    {
      "src": "/token$",
      "dest": "/frontend/token.html"
    },
    {
      "src": "/profile$",
      "dest": "/frontend/profile.html"
    },
    {
      "src": "/communities$",
      "dest": "/frontend/communities.html"
    },
    {
      "src": "/communities/(.*)",
      "dest": "/frontend/communities.html"
    },
    {
      "src": "/go$",
      "dest": "/frontend/go.html"
    },
    {
      "src": "/go/(.*)",
      "dest": "/frontend/go.html"
    },
    {
      "src": "/agents$",
      "dest": "/frontend/agents.html"
    },
    {
      "src": "/agents/(.*)",
      "dest": "/frontend/agents.html"
    },
    {
      "src": "/skill\\.md$",
      "dest": "/frontend/skill.md"
    },
    {
      "src": "/alpha$",
      "dest": "/frontend/alpha.html"
    },
    {
      "src": "/alpha/(.*)",
      "dest": "/frontend/alpha.html"
    },
    {
      "src": "/onboard$",
      "dest": "/frontend/onboard.html"
    },
    {
      "src": "/airdrop$",
      "dest": "/frontend/airdrop.html"
    },
    {
      "src": "/rh-swap$",
      "dest": "/frontend/rh-swap.html"
    },
    {
      "src": "/swap$",
      "dest": "/frontend/rh-swap.html"
    },
    {
      "src": "/robinhood-swap$",
      "dest": "/frontend/rh-swap.html"
    },
    {
      "src": "/referrals$",
      "dest": "/frontend/referrals.html"
    },
    {
      "src": "/r/(.*)",
      "dest": "/frontend/referrals.html"
    },
    {
      "src": "/social$",
      "dest": "/frontend/social.html"
    },
    {
      "src": "/pumpr-card$",
      "dest": "/frontend/pumpr-card.html"
    },
    {
      "src": "/android$",
      "dest": "/frontend/android.html"
    },
    {
      "src": "/terms$",
      "dest": "/frontend/terms.html"
    },
    {
      "src": "/privacy$",
      "dest": "/frontend/privacy.html"
    },
    {
      "src": "/card$",
      "dest": "/frontend/pumpr-card.html"
    },
    {
      "src": "/home$",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/$",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
