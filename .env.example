MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
BASE_RPC_URL=https://mainnet.base.org
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
PUMPFUN_SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
HELIUS_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_RPC_URLS=https://rpc-one.example,https://rpc-two.example
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY
FEE_RECIPIENT=0xYOUR_FEE_WALLET
PLATFORM_FEE_RECIPIENT=0x024469De02f5efFc7c10667f3e2A852Bd4a5149f
FEE_BPS=50
LAUNCH_FEE_ETH=0.0015
VIRTUAL_ETH_RESERVE=0.5
VIRTUAL_TOKEN_RESERVE=1000000
# Defaults to a ~$40k bond target when GRADUATION_TARGET_ETH is omitted.
# Example at $3k/ETH: 40000 / 3000 = 13.333333333333333333 ETH.
GRADUATION_TARGET_USD=40000
GRADUATION_TARGET_QUOTE_USD=3000
# Optional exact quote-token target override.
# GRADUATION_TARGET_ETH=13.333333333333333333
DEX_ROUTER=0xUNISWAP_V2_ROUTER
LP_RECIPIENT=0xLP_TOKEN_RECEIVER
V3_POSITION_MANAGER=0xUNISWAP_V3_NONFUNGIBLE_POSITION_MANAGER
V3_SWAP_ROUTER=0xUNISWAP_V3_SWAP_ROUTER
V3_FEE=10000
CHAIN_ID=1
FACTORY_ADDRESS=0xDEPLOYED_FACTORY_ON_CHAIN
FACTORY_ADDRESS_8453=0xDEPLOYED_BASE_FACTORY
FACTORY_ADDRESS_4663=0xDEPLOYED_ROBINHOOD_FACTORY
FACTORY_ADDRESSES={"1":"0xMAINNET_FACTORY","8453":"0xBASE_FACTORY","4663":"0xROBINHOOD_FACTORY"}
RPC_URLS_BY_CHAIN={"1":["https://mainnet.infura.io/v3/YOUR_KEY"],"8453":["https://mainnet.base.org"],"4663":["https://rpc.mainnet.chain.robinhood.com"]}
UPLOAD_MODE=disk
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROFILE_TABLE=user_profiles
SUPABASE_FOLLOW_TABLE=user_follows
SUPABASE_STORAGE_BUCKET=uploads
SUPABASE_COMMUNITY_OBJECT=community/community.json
SUPABASE_ALPHA_OBJECT=alpha/alpha.json
SUPABASE_AGENTS_OBJECT=agents/agents.json
SUPABASE_SCHEMA=public
SUPABASE_PUMPFUN_PREPARED_OBJECT=pumpfun/prepared-submissions.json
SUPABASE_PUMPFUN_SESSIONS_OBJECT=pumpfun/sessions.json
SUPABASE_PUMPFUN_LAUNCHES_OBJECT=pumpfun/launches.json
SUPABASE_PUMPFUN_METADATA_OBJECT=pumpfun/metadata.json
SUPABASE_SUPPORT_OBJECT=support/messages.json
SUPABASE_PUMPR_CARD_WAITLIST_OBJECT=pumpr-card/waitlist.json
SUPABASE_REFERRAL_OBJECT=referrals/referrals.json
STRICT_PROFILE_STORE=1
STRICT_SOCIAL_STORE=1
STRICT_JSON_STORE=1
STRICT_UPLOAD_STORE=1
REFERRAL_CRON_SECRET=optional-cron-secret
X_CLIENT_ID=your-x-oauth-client-id
X_CLIENT_SECRET=your-x-oauth-client-secret
# Local: http://localhost:4173/api/x/oauth/callback
# Production: https://pump-r.fun/api/x/oauth/callback
# Optional. If omitted, the server derives it from the current request host.
X_CALLBACK_URL=http://localhost:4173/api/x/oauth/callback

# Official Pump-r/Pump.fun token gate.
# Set this after launching the Pump-r token. Users must hold it to launch through
# the app and to claim creator payments. Set chain ID 101 for the Pump.fun/Solana mint.
PUMPR_TOKEN_ADDRESS=C64Fr3nt6S9mmbehCS66Y1HYLnwBdMeUCdTimfmvpump
PUMPR_TOKEN_CHAIN_ID=101
PUMPR_HOLDER_GATE_REQUIRED=1
PUMPR_AIRDROP_MIN_HOLDER_PCT=0.5
PUMPR_AIRDROP_MIN_HOLD_DAYS=7
AIRDROP_TOKEN_NAME=Pumpfun Remastered
AIRDROP_TOKEN_SYMBOL=PUMPR
AIRDROP_MESSAGE=Pumpfun Remastered airdrops are reserved for current live non-dev holders with at least 0.5% of supply at snapshot.

# Agent + bounty AI.
# OPENAI_API_KEY enables AI bounty drafts, agent runs, and optional generated
# task-scene images from the embedded GO agent submit panel.
OPENAI_API_KEY=your-openai-api-key
OPENAI_AGENT_MODEL=gpt-4.1-mini
OPENAI_AGENT_MAX_OUTPUT_TOKENS=3000
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024

# Airi X automation. In GitHub Actions, store these as repository secrets or
# variables with the same names so Airi can post from @Pumpr_Intern.
OPENAI_AIRI_TWEET_MODEL=gpt-4.1-mini
TWEXAPI_BEARER_TOKEN=your-twexapi-token
TWEXAPI_X_COOKIE=your-airi-x-cookie
TWEXAPI_PROXY=
AIRI_TWEET_ENABLED=true
AIRI_TWEET_DRY_RUN=false
AIRI_TWEET_REQUIRE_POST=true
AIRI_TWEET_MAX_CHARS=125
AIRI_WORLD_POST_CHANCE=0.9
AIRI_WORLD_MIN_HOURS=1

# Live Pump.fun GO bounty sync.
ENABLE_PUMPFUN_BOUNTIES=1
PUMPFUN_BOUNTIES_URL=https://pump.fun/go
PUMPFUN_BOUNTY_CACHE_TTL_MS=60000
PUMPFUN_BOUNTY_DETAIL_CACHE_TTL_MS=120000
PUMPFUN_LIVESTREAM_API_URL=https://livestream-api.pump.fun

# Optional Pump.fun launch mint vanity suffix.
# Leave disabled for normal Pump.fun SDK launches.
PUMPFUN_MINT_SUFFIX_ENABLED=1
PUMPFUN_MINT_SUFFIX=pr
PUMPFUN_MINT_SUFFIX_MAX_ATTEMPTS=25000

# @pumpr_fun X mention launch intake.
# The scheduled GitHub workflow reads mentions, uses AI/rules to keep only real
# launch requests, asks for missing launchpad/image/name/ticker/description, and
# can launch Pump.fun tokens through the existing Pump-r backend when enabled.
PUMPR_X_USERNAME=pumpr_fun
PUMPR_X_USER_ID=
X_LAUNCH_MENTION_SOURCE=twex
PUMPR_X_BEARER_TOKEN=optional-official-x-app-bearer-token-if-X_LAUNCH_MENTION_SOURCE-is-official
PUMPR_X_USER_ACCESS_TOKEN=optional-x-user-oauth-token-for-official-replies
PUMPR_TWEX_X_COOKIE=your-pumpr-fun-x-cookie-for-twex-replies
X_LAUNCH_SOLANA_PRIVATE_KEY=store-this-only-as-a-github-or-vercel-secret
X_LAUNCH_AUTOPILOT_ENABLED=false
X_LAUNCH_ALLOW_PUBLIC=false
X_LAUNCH_ALLOWED_USERNAMES=pumpr_fun
X_LAUNCH_ALLOWED_USER_IDS=
X_LAUNCH_DRY_RUN=false
X_LAUNCH_MAX_MENTIONS=20
X_LAUNCH_EMPTY_FETCH_BACKOFF_MINUTES=0
X_LAUNCH_ACTIVE_FETCH_BACKOFF_MINUTES=0
X_LAUNCH_LOOP_INTERVAL_SECONDS=30
X_LAUNCH_LOOP_RUNS=9
X_LAUNCH_TWEX_READ_DELAY_MS=5500
X_LAUNCH_PUBLIC_SEARCH_TERMS=@pumpr_fun -from:pumpr_fun|"@pumpr_fun" -from:pumpr_fun|to:pumpr_fun -from:pumpr_fun
OPENAI_X_LAUNCH_MODEL=gpt-4.1-mini
