# Optional. If omitted, the server derives it from the current request host.
X_CALLBACK_URL=http://localhost:4173/api/x/oauth/callback

# Official Pump-r/Pump.fun token gate.
# Set this after launching the Pump-r token. Users must hold it to launch through
# the app and to claim creator payments. Set chain ID 101 for the Pump.fun/Solana mint.
PUMPR_TOKEN_ADDRESS=C64Fr3nt6S9mmbehCS66Y1HYLnwBdMeUCdTimfmvpump
PUMPR_TOKEN_CHAIN_ID=101
PUMPR_HOLDER_GATE_REQUIRED=1
PUMPR_AIRDROP_MIN_HOLDER_PCT=1
PUMPR_AIRDROP_MIN_HOLD_DAYS=7
AIRDROP_TOKEN_NAME=Pumpfun Remastered
AIRDROP_TOKEN_SYMBOL=PUMPR
AIRDROP_MESSAGE=Pumpfun Remastered airdrops are reserved for top holders who keep holding long term.

# Agent + bounty AI.
# OPENAI_API_KEY enables AI bounty drafts, agent runs, and optional generated
# task-scene images from the embedded GO agent submit panel.
OPENAI_API_KEY=your-openai-api-key
OPENAI_AGENT_MODEL=gpt-4.1-mini
OPENAI_AGENT_MAX_OUTPUT_TOKENS=3000
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024

# Live Pump.fun GO bounty sync.
ENABLE_PUMPFUN_BOUNTIES=1
PUMPFUN_BOUNTIES_URL=https://pump.fun/go
PUMPFUN_BOUNTY_CACHE_TTL_MS=60000
PUMPFUN_BOUNTY_DETAIL_CACHE_TTL_MS=120000
PUMPFUN_LIVESTREAM_API_URL=https://livestream-api.pump.fun

# Pump.fun launch mint vanity suffix.
# Default is pr, so new Solana/Pump.fun launch CAs end with "pr".
PUMPFUN_MINT_SUFFIX=pr
PUMPFUN_MINT_SUFFIX_MAX_ATTEMPTS=25000
